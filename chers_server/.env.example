# Telemetry Configuration
# Copy this file to .env and configure for local development

# OpenTelemetry OTLP endpoint (required for OTEL mode)
# Default Aspire Dashboard: http://localhost:18889
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:18889

# Sentry DSN (required for Sentry mode)
# Get from Sentry project settings > Client Keys (DSN)
# Leave unset to disable Sentry
# SENTRY_DSN=https://...@sentry.io/...

# Service name for OTEL (optional, defaults to 'chers-server')
# OTEL_SERVICE_NAME=chers-server

# Sampling rates (0.0-1.0, 1.0 = 100%)
OTEL_TRACES_SAMPLER_ARG=1.0
SENTRY_TRACES_SAMPLE_RATE=1.0

# Server port (optional, defaults to 3000)
# PORT=3000
